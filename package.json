{
  "name": "fund-manager",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "pnpm --filter @fund-manager/web dev",
    "dev:api": "pnpm --filter @fund-manager/api dev",
    "db:generate": "pnpm --filter @fund-manager/database generate",
    "db:push": "pnpm --filter @fund-manager/database push",
    "db:migrate": "pnpm --filter @fund-manager/database migrate",
    "db:studio": "pnpm --filter @fund-manager/database studio"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2"
  }
}
